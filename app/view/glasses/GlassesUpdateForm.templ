package glasses

import (
	"fmt"
	"github.com/FACorreiaa/glasses-management-platform/app/models"
	"github.com/FACorreiaa/glasses-management-platform/app/view/components"
)

templ GlassesUpdateForm(currentGlasses models.Glasses, form models.GlassesForm, id string) {
	<section class="w-full bg-white py-8">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<h2 class="mb-6 text-3xl font-extrabold text-gray-900 xl:text-4xl">Update Glasses</h2>
			<form method="post" class="w-full space-y-6">

				<!-- Reference Identifier -->
				<div>
					<label class="block text-sm font-medium leading-6 text-gray-900 dark:text-gray-200" for="reference">Reference / SKU</label>
					<div class="mt-2">
						<input
							type="text"
							class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
							placeholder="E.g. G-1024-B"
							name="reference"
							autocomplete="off"
							id="reference"
							required
							value={ form.Values["reference"] }
						/>
					</div>
					if form.FieldErrors["reference"] != "" {
						<p class="mt-2 text-sm text-error">{ form.FieldErrors["reference"] }</p>
					}
				</div>

				<!-- Left Eye Prescription -->
				<div class="border-t border-gray-200 dark:border-gray-700 pt-8">
					<h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">Left Eye (L)</h3>
					<p class="mt-1 text-sm leading-6 text-gray-500">Optical measurements for the left eye.</p>
					<div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-4">
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="left_sph">Sph</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0.00"
									name="left_sph"
									id="left_sph"
									step="0.05"
									value={ form.Values["left_sph"] }
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="left_cyl">Cyl</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0.00"
									name="left_cyl"
									id="left_cyl"
									step="0.05"
									value={ form.Values["left_cyl"] }
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="left_axis">Axis</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0"
									name="left_axis"
									id="left_axis"
									min="0"
									max="180"
									value={ form.Values["left_axis"] }
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="left_add">Add</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0.00"
									name="left_add"
									id="left_add"
									step="0.05"
									value={ form.Values["left_add"] }
								/>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Eye Prescription -->
				<div class="border-t border-gray-200 dark:border-gray-700 pt-8">
					<h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">Right Eye (R)</h3>
					<p class="mt-1 text-sm leading-6 text-gray-500">Optical measurements for the right eye.</p>
					<div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-4">
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="right_sph">Sph</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0.00"
									name="right_sph"
									id="right_sph"
									step="0.05"
									value={ form.Values["right_sph"] }
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="right_cyl">Cyl</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0.00"
									name="right_cyl"
									id="right_cyl"
									step="0.05"
									value={ form.Values["right_cyl"] }
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="right_axis">Axis</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0"
									name="right_axis"
									id="right_axis"
									min="0"
									max="180"
									value={ form.Values["right_axis"] }
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider" for="right_add">Add</label>
							<div class="mt-1">
								<input
									type="number"
									class="block w-full rounded-md border-0 py-1.5 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
									placeholder="0.00"
									name="right_add"
									id="right_add"
									step="0.05"
									value={ form.Values["right_add"] }
								/>
							</div>
						</div>
					</div>
				</div>

				<div class="border-t border-gray-200 dark:border-gray-700 pt-8">
					<h3 class="text-sm font-semibold leading-6 text-gray-900 dark:text-white">Inventory Status</h3>
					<div class="mt-4 flex items-center gap-3">
						<input
							id="restock"
							name="restock"
							type="checkbox"
							value="true"
							class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-primary focus:ring-primary"
						/>
						if currentGlasses.IsInStock {
							<label for="restock" class="text-sm text-gray-500">
								Item is currently in stock.
							</label>
						} else {
							<label for="restock" class="text-sm font-medium text-gray-700 dark:text-gray-300">
								Mark as returned and restock item <span class="text-xs text-gray-500 font-normal ml-1">(This will delete the customer shipping link)</span>
							</label>
						}
					</div>
				</div>

				<!-- Section 5: Actions -->
				<div class="flex flex-col sm:flex-row justify-center space-y-2 sm:space-y-0 sm:space-x-4 pt-6 border-t border-gray-200 dark:border-gray-700">
					@components.ButtonReturnComponent(templ.SafeURL("/glasses"))
					@components.ButtonUpdateComponent(string(templ.URL(fmt.Sprintf("/glasses/%s/update", id))), "Update Glasses")
				</div>
			</form>
		</div>
	</section>
}

